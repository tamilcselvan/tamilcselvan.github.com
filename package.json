{
  "name": "portfolio-website",
  "version": "1.0.0",
  "description": "Tamil Selvan C's professional portfolio website",
  "main": "index.html",
  "scripts": {
    "dev": "npx tailwindcss -i ./scss/style.scss -o ./css/style.css --watch",
    "build": "npx tailwindcss -i ./scss/style.scss -o ./css/style.css --minify",
    "build:prod": "NODE_ENV=production npx tailwindcss -i ./scss/style.scss -o ./css/style.css --minify",
    "serve": "npx http-server . -p 3000 -o",
    "dev:serve": "concurrently \"npm run dev\" \"npm run serve\"",
    "lint:css": "npx stylelint \"scss/**/*.scss\"",
    "format": "npx prettier --write \"**/*.{html,css,scss,js,json,md}\"",
    "optimize:images": "node scripts/optimize-images.mjs"
  },
  "dependencies": {
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "http-server": "^14.1.1",
    "postcss": "^8.5.16",
    "prettier": "^3.1.0",
    "sharp": "^0.35.3",
    "stylelint": "^15.11.0",
    "stylelint-config-standard-scss": "^11.1.0"
  },
  "keywords": [
    "portfolio",
    "website",
    "tailwindcss",
    "responsive",
    "accessibility"
  ],
  "author": "Tamil Selvan C",
  "license": "MIT"
}
